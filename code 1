<h2>Enter 3 Names</h2> 
<form method="POST"> 
    Name 1: <input type="text" name="name[]"><br><br> 
    Name 2: <input type="text" name="name[]"><br><br> 
    Name 3: <input type="text" name="name[]"><br><br> 
    <input type="submit" value="Submit"> 
</form> 
<?php 
if ($_SERVER["REQUEST_METHOD"] == "POST") { 
    $names = $_POST['name']; // array 
    echo "<h3>Names Entered:</h3>"; 
    foreach ($names as $n) { 
        echo $n . "<br>"; 
    } 
} 
?> 
